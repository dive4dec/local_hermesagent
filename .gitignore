# Environment and credentials
.env
.env.*
credentials.json
*_secret*

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
*.egg
.venv/
venv/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

