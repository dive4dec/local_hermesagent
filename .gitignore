localcache/
moodledata/

# Temporary files
/tmp/*
*.tmp
*.log

# AMD build files ARE committed — end users who download the zip need them.
# Only ignore dev-only vendor packages that can be re-fetched.
amd/build/vendor/

# SSH keys
*.pem
*.key
id_rsa*
